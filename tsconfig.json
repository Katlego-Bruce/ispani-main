{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@ispani/shared": ["packages/shared/src"],
      "@ispani/ui": ["packages/ui/src"],
      "@ispani/utils": ["packages/utils/src"],
      "@ispani/sdk": ["packages/sdk/src"]
    }
  },
  "exclude": ["node_modules"]
}